{
  "actions": [

    // Play card from hand
    { "id": "SAA", "action": "-> PlayCard<Class<ProjectCard>>" },

    // Use standard project
    { "id": "SAB", "action": "-> UseAction<StandardProject>" },

    // Claim milestone
    { "id": "SAC", "action": "8 -> Milestone" },

    // Fund award
    // { "id": "SAD", "action": "6, 8 / Award -> Award" },

    // Use card action
    {
      "id": "SAE",
      "action": "-> UseAction<ActionCard>, ActionUsedMarker<ActionCard>"
    },

    // Convert plants
    { "id": "SAF", "action": "8 Plant -> GreeneryTile" },

    // Convert heat
    { "id": "SAG", "action": "8 Heat -> TemperatureStep" },

    // SAI = send delegate

    // Sell patents[F] - yes, it's technically a project, but that makes things annoying
    { "id": "SELL", "action": "X ProjectCard -> X" },

    // Mandatory first action; it's always here but you can't take it if you have 0 Mandate
    { "id": "MAND", "action": "-> Mandate: MandateSignal" }
  ],

  "projects": [

    // Power Plant
    { "id": "SP11", "action": "11 -> PROD[Energy]" },

    // Asteroid
    { "id": "SP14", "action": "14 -> TemperatureStep" },

    // Aquifer
    { "id": "SP18", "action": "18 -> OceanTile" },

    // Greenery
    { "id": "SP23", "action": "23 -> GreeneryTile" },

    // City
    { "id": "SP25", "action": "25 -> PROD[1], CityTile" },
  ],
}
